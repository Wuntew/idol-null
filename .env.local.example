# Supabase - from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron security - generate a random string of at least 16 characters.
# Vercel sends this as Authorization: Bearer <CRON_SECRET> for cron invocations.
CRON_SECRET=your-random-secret-here

# Resend is optional and only needed if email summaries are enabled.
RESEND_API_KEY=re_your_key_here
RESEND_FROM=noreply@yourdomain.com

# OpenAI is optional. When configured, cron generates narrative feed lines,
# episode recaps, and castaway memory updates after deterministic simulation.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Admin console (/admin) - generate a long random password. Without this set,
# the admin console is unreachable (login always fails closed).
ADMIN_SECRET=choose-a-long-random-password
